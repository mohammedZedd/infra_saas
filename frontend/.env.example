# Copy this file to .env and fill in the correct values.
# Do NOT commit .env to version control.

# Relative path used by the Vite dev proxy (see vite.config.ts → server.proxy).
# The proxy forwards /api/* → http://localhost:8000/* (backend server).
# For production, use a full URL: https://api.yourapp.com
VITE_API_URL=/api/v1
